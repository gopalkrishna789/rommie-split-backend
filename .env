# Local dev — uses SQLite (no PostgreSQL needed)
# DATABASE_URL is intentionally left blank to trigger SQLite mode
DATABASE_URL=
SQLITE_PATH=./roomie.db

REDIS_URL=redis://localhost:6379
JWT_SECRET=roomie-split-dev-secret-change-in-production-2024
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:dev@roomiesplit.local
FIREBASE_SERVICE_ACCOUNT_JSON=
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
