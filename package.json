{
  "name": "roomie-split-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Roomie Split backend - Fastify + PostgreSQL + Redis + Socket.io",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "psql $DATABASE_URL -f src/db/migrations/001_init.sql",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "firebase-admin": "^12.1.0",
    "jspdf": "^2.5.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
